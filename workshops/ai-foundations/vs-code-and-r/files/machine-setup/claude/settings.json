{
  "permissions": {
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(> *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(brew *)",
      "Bash(apt *)",
      "Bash(pip *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git branch -D *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git clean *)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(defaults *)"
    ],
    "allow": [
      "Read",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(Rscript *)",
      "Bash(quarto render *)",
      "Bash(quarto preview *)",
      "Bash(R -e *)",
      "Bash(R --version)",
      "Bash(quarto --version)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "ask": [
      "Bash(echo *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [".", "~/.claude", "/tmp"],
      "denyWrite": ["~/", "/var", "/etc", "/usr"],
      "allowRead": [".", "~/.claude", "~/Library/R", "/Library/Frameworks/R.framework", "/usr/local/lib/R", "/tmp"],
      "denyRead": ["~/", "/var", "/etc"]
    }
  }
}
